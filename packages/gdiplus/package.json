{
  "author": "Stev Peifer <stev.p@outlook.com>",
  "bugs": {
    "url": "https://github.com/ObscuritySRL/bun-win32/issues"
  },
  "dependencies": {
    "@bun-win32/core": "workspace:*"
  },
  "description": "Zero-dependency, zero-overhead Win32 GDI+ bindings for Bun (FFI) on Windows — image load/save, antialiased 2D drawing, fonts, paths, brushes, color matrix effects.",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "exports": {
    ".": "./index.ts"
  },
  "license": "MIT",
  "module": "index.ts",
  "name": "@bun-win32/gdiplus",
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": false,
  "homepage": "https://github.com/ObscuritySRL/bun-win32#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/ObscuritySRL/bun-win32.git",
    "directory": "packages/gdiplus"
  },
  "type": "module",
  "version": "1.0.2",
  "main": "./index.ts",
  "keywords": [
    "bun",
    "ffi",
    "win32",
    "windows",
    "gdiplus",
    "gdi+",
    "image",
    "png",
    "jpeg",
    "graphics",
    "2d",
    "rendering",
    "bindings",
    "typescript",
    "dll"
  ],
  "files": [
    "AI.md",
    "README.md",
    "index.ts",
    "structs/*.ts",
    "types/*.ts"
  ],
  "sideEffects": false,
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "example:generative-poster": "bun ./example/generative-poster.ts",
    "example:image-diagnostic": "bun ./example/image-diagnostic.ts"
  }
}
