    "bun": ">=1.1.0"
  },
  "scripts": {
    "example:benchmark": "bun ./example/benchmark.ts",
    "example:crosscheck": "bun ./example/crosscheck.ts",
    "example:etw-firehose": "bun ./example/etw-firehose.ts",
    "example:event-tail": "bun ./example/event-tail.ts",
    "example:hello-sysmon": "bun ./example/hello-sysmon.ts",
    "example:selftest": "bun ./example/sysmon.selftest.ts",
