    "@types/bun": "latest"
  },
  "exports": {
    ".": "./index.ts"
  },
  "license": "MIT",
  "module": "index.ts",
  "name": "bun-netdiag",
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": false,
  "homepage": "https://github.com/ObscuritySRL/bun-win32#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/ObscuritySRL/bun-win32.git",
    "directory": "packages/bun-netdiag"
  },
  "type": "module",
  "version": "1.0.0",
  "main": "./index.ts",
  "keywords": [
    "bun",
    "ffi",
    "win32",
    "windows",
    "network",
    "netstat",
    "ping",
    "traceroute",
    "dns",
    "wifi",
    "arp",
    "routing",
    "diagnostics",
    "typescript"
  ],
  "files": [
    "README.md",
    "index.ts"
  ],
  "sideEffects": false,
  "engines": {
    "bun": ">=1.1.0"
  }
