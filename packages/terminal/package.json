    "directory": "packages/terminal"
  },
  "type": "module",
  "version": "1.1.0",
  "main": "./index.ts",
  "keywords": [
    "bun",
    "ffi",
    "win32",
    "windows",
    "terminal",
    "tui",
    "ansi",
