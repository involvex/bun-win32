{
  "author": "Stev Peifer <stev.p@outlook.com>",
  "bugs": {
    "url": "https://github.com/ObscuritySRL/bun-win32/issues"
  },
  "dependencies": {
    "@bun-win32/core": "workspace:*"
  },
  "devDependencies": {
    "@bun-win32/kernel32": "workspace:*",
    "@types/bun": "latest"
  },
  "description": "Zero-dependency, zero-overhead Win32 OLEAUT32 bindings for Bun (FFI) on Windows.",
  "exports": {
    ".": "./index.ts"
  },
  "license": "MIT",
  "module": "index.ts",
  "name": "@bun-win32/oleaut32",
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": false,
  "homepage": "https://github.com/ObscuritySRL/bun-win32#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/ObscuritySRL/bun-win32.git",
    "directory": "packages/oleaut32"
  },
  "type": "module",
  "version": "1.0.1",
  "main": "./index.ts",
  "keywords": [
    "bun",
    "ffi",
    "win32",
    "windows",
    "oleaut32",
    "ole",
    "ole-automation",
    "com",
    "bstr",
    "variant",
    "safearray",
    "idispatch",
    "typelib",
    "decimal",
    "currency",
    "bindings",
    "typescript",
    "dll"
  ],
  "files": [
    "AI.md",
    "README.md",
    "index.ts",
    "structs/*.ts",
    "types/*.ts"
  ],
  "sideEffects": false,
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "example:typelib-explorer": "bun ./example/typelib-explorer.ts",
    "example:variant-conversion-matrix": "bun ./example/variant-conversion-matrix.ts"
  }
}
