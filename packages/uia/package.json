  "description": "Playwright for the Windows desktop, from Bun — drive the UI Automation accessibility tree (find by name, invoke, type, assert), plus synthetic input, full-screen capture + image matching, native-window introspection (Spy++-style), an LLM computer-use adapter, and an MCP server. Zero native dependencies, no node-gyp, no server.",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "exports": {
    ".": "./index.ts",
    "./mcp": "./mcp.ts"
  },
  "bin": {
    "bun-uia-mcp": "./mcp.ts"
  },
  "license": "MIT",
  "module": "index.ts",
  "name": "@bun-win32/uia",
  "peerDependencies": {
    "typescript": "^5"
