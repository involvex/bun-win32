{
  "author": "Stev Peifer <stev.p@outlook.com>",
  "bugs": {
    "url": "https://github.com/ObscuritySRL/bun-win32/issues"
  },
  "dependencies": {
    "@bun-win32/combase": "workspace:*",
    "@bun-win32/core": "workspace:*",
    "@bun-win32/gdi32": "workspace:*",
    "@bun-win32/kernel32": "workspace:*",
    "@bun-win32/oleacc": "workspace:*",
    "@bun-win32/oleaut32": "workspace:*",
    "@bun-win32/user32": "workspace:*"
  },
  "description": "Playwright for the Windows desktop, from Bun — drive the UI Automation accessibility tree (find by name, invoke, type, assert), plus synthetic input, full-screen capture + image matching, native-window introspection (Spy++-style), an LLM computer-use adapter, and an MCP server. Zero native dependencies, no node-gyp, no server.",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "exports": {
    ".": "./index.ts",
    "./mcp": "./mcp.ts"
  },
  "bin": {
    "bun-uia-mcp": "./mcp.ts"
  },
  "license": "MIT",
  "module": "index.ts",
  "name": "@bun-win32/uia",
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/ObscuritySRL/bun-win32#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/ObscuritySRL/bun-win32.git",
    "directory": "packages/uia"
  },
  "type": "module",
  "version": "1.2.0",
  "main": "./index.ts",
  "keywords": [
    "accessibility",
    "automation",
    "bun",
    "desktop",
    "e2e",
    "ffi",
    "playwright",
    "testing",
    "typescript",
    "uiautomation",
    "win32",
    "windows"
  ],
  "files": [
    "AI.md",
