{
  "author": "Stev Peifer <stev.p@outlook.com>",
  "bugs": {
    "url": "https://github.com/ObscuritySRL/bun-win32/issues"
  },
  "dependencies": {
    "@bun-win32/uia": "workspace:*"
  },
  "description": "Playwright for the Windows desktop, from Bun — drive and test native GUIs via the UI Automation tree (find by name, invoke, type, assert), plus synthetic input, full-screen capture + image matching, native-window introspection (Spy++-style), an LLM computer-use adapter, and an MCP server. Zero native dependencies, no node-gyp, no server.",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "exports": {
    ".": "./index.ts",
    "./mcp": "./mcp.ts"
  },
  "bin": {
    "bun-uia": "./mcp.ts",
    "bun-uia-mcp": "./mcp.ts"
  },
  "license": "MIT",
  "mcpName": "io.github.ObscuritySRL/bun-uia",
  "module": "index.ts",
  "name": "bun-uia",
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": false,
  "homepage": "https://github.com/ObscuritySRL/bun-win32#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/ObscuritySRL/bun-win32.git",
    "directory": "packages/bun-uia"
  },
  "type": "module",
  "version": "1.7.0",
  "main": "./index.ts",
  "keywords": [
    "accessibility",
    "automation",
    "bun",
    "desktop",
    "e2e",
    "ffi",
    "playwright",
    "testing",
    "typescript",
    "uiautomation",
    "win32",
    "windows"
  ],
  "files": [
    "README.md",
    "index.ts",
    "mcp.ts"
  ],
  "sideEffects": false,
  "engines": {
    "bun": ">=1.1.0"
  }
}
