{
  "author": "Stev Peifer <stev.p@outlook.com>",
  "bugs": {
    "url": "https://github.com/ObscuritySRL/bun-win32/issues"
  },
  "dependencies": {
    "@bun-win32/core": "workspace:*"
  },
  "description": "Zero-dependency, zero-overhead Win32 DBGHELP bindings for Bun (FFI) on Windows.",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "exports": {
    ".": "./index.ts"
  },
  "license": "MIT",
  "module": "index.ts",
  "name": "@bun-win32/dbghelp",
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": false,
  "homepage": "https://github.com/ObscuritySRL/bun-win32#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/ObscuritySRL/bun-win32.git",
    "directory": "packages/dbghelp"
  },
  "type": "module",
  "version": "1.0.2",
  "main": "./index.ts",
  "keywords": [
    "bun",
    "ffi",
    "win32",
    "windows",
    "dbghelp",
    "bindings",
    "typescript",
    "dll"
  ],
  "files": [
    "AI.md",
    "README.md",
    "index.ts",
    "structs/*.ts",
    "types/*.ts"
  ],
  "sideEffects": false,
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "example:symbol-explorer": "bun ./example/symbol-explorer.ts",
    "example:crash-report": "bun ./example/crash-report.ts"
  }
}
